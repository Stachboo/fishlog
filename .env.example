# Database (PostgreSQL via Drizzle ORM)
DATABASE_URL=

# Auth.js v5
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (Auth.js provider)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Weather API (OpenWeatherMap)
OPENWEATHERMAP_API_KEY=

# Upstash Redis (rate limiting + caching)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Upstash QStash (background jobs: weather batch)
UPSTASH_QSTASH_TOKEN=

# Web Push (VAPID keys — generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# VAPID public key exposed to the browser (same value as VAPID_PUBLIC_KEY)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Admin (single-user admin, no RBAC)
ADMIN_EMAIL=

# Feature flags
ENABLE_PUSH=true
ENABLE_OFFLINE=true
# Public feature flags (exposed to browser)
NEXT_PUBLIC_ENABLE_OFFLINE=true
